{
  "compilerOptions": {
    "target": "ES3",
    "ignoreDeprecations": "5.0",
    "outDir": "./dist/",
    "noLib": true,
    "noEmit": false,
    "removeComments": true,
    "useDefineForClassFields": false,
    "noUnusedParameters": true,
    "noUnusedLocals": true,
    "module": "ES6",
    "allowSyntheticDefaultImports": true,
    "forceConsistentCasingInFileNames": true,
    "strict": true,
    "skipLibCheck": true,
    "strictNullChecks": true,
    "esModuleInterop": true
  },
  "ts-node": {
    "compilerOptions": {
      "module": "CommonJS",
      "noLib": false,
      "allowJs": true,
      "types": [
        "node"
      ]
    }
  },
  "include": [
    "index.ts",
    "src",
    "tests",
    "zd.ts"
  ]
}